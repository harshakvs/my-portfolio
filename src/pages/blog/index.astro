---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { profile } from '../../data/profile';
import { url } from '../../data/url';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<Base title={`Writing | ${profile.name}`} description="Articles on inference engineering, MLOps, and building models from scratch.">
  <main class="section">
    <div class="container">
      <h1 class="section-title">ls ./writing</h1>
      <p class="section-sub">Everything ships here first, then gets cross-posted to Medium.</p>
      <div class="list">
        {posts.map((post) => (
          <a class="row card" href={post.data.status === 'published' ? url(`/blog/${post.id.replace(/\.md$/, '')}`) : undefined}>
            <span class="mono meta">
              {post.data.status === 'coming-soon' ? <span class="soon">◐ in progress</span> : post.data.pubDate.toISOString().slice(0, 10)}
            </span>
            <div>
              <h2>{post.data.title}</h2>
              <p class="muted">{post.data.description}</p>
            </div>
            <span class="tags">{post.data.tags.map((t) => <span class="tag alt">{t}</span>)}</span>
          </a>
        ))}
      </div>
    </div>
  </main>
</Base>

<style>
  .list { display: flex; flex-direction: column; gap: 14px; }
  .row { display: grid; grid-template-columns: 130px 1fr auto; gap: 20px; align-items: center; }
  .row:hover { text-decoration: none; }
  .row:not([href]) { opacity: 0.7; cursor: default; }
  .row:not([href]):hover { transform: none; box-shadow: none; border-color: var(--border); }
  .meta { font-size: 0.72rem; color: var(--muted); }
  .soon { color: var(--amber); }
  h2 { font-size: 1rem; color: var(--text); margin-bottom: 4px; }
  .row[href]:hover h2 { color: var(--accent); }
  .row p { font-size: 0.85rem; }
  .tags { display: flex; gap: 6px; }
  @media (max-width: 720px) { .row { grid-template-columns: 1fr; gap: 8px; } .tags { flex-wrap: wrap; } }
</style>
