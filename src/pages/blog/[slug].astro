---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { profile } from '../../data/profile';
import { url } from '../../data/url';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.status === 'published');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={`${post.data.title} | ${profile.name}`} description={post.data.description}>
  <main class="section">
    <article class="container post">
      <p class="mono back"><a href={url('/blog')}>← cd ..</a></p>
      <p class="mono meta muted">
        {post.data.pubDate.toISOString().slice(0, 10)} · {post.data.tags.map((t) => <span class="tag alt">{t}</span>)}
      </p>
      <h1>{post.data.title}</h1>
      <p class="lede muted">{post.data.description}</p>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</Base>

<style>
  .post { max-width: 720px; }
  .back { margin-bottom: 32px; font-size: 0.85rem; }
  .meta { display: flex; gap: 8px; align-items: center; font-size: 0.75rem; margin-bottom: 16px; }
  h1 { font-size: clamp(1.5rem, 4vw, 2.2rem); margin-bottom: 12px; }
  .lede { font-size: 1.05rem; margin-bottom: 40px; }
  .prose :global(h2) { font-size: 1.2rem; margin: 36px 0 14px; color: var(--accent); }
  .prose :global(h2)::before { content: '## '; color: var(--border-bright); }
  .prose :global(p) { margin-bottom: 18px; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 18px 24px; }
  .prose :global(li) { margin-bottom: 6px; }
  .prose :global(code) { font-family: var(--font-mono); font-size: 0.85em; background: var(--panel); border: 1px solid var(--border); border-radius: 5px; padding: 1px 6px; }
  .prose :global(pre) { background: #070b11; border: 1px solid var(--border); border-radius: 10px; padding: 18px; overflow-x: auto; margin-bottom: 18px; }
  .prose :global(pre code) { background: none; border: none; padding: 0; }
  .prose :global(strong) { color: var(--text); }
</style>
