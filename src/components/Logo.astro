---
interface Props { size?: number }
const { size = 40 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 64 64" aria-label="SK logo" role="img">
  <rect x="1.5" y="1.5" width="61" height="61" rx="14" fill="#0b111b" stroke="#1e2c40" stroke-width="1.5"/>
  <line x1="24" y1="30" x2="36" y2="30" stroke="#2a3d58" stroke-width="1.5"/>
  <polyline points="24,18 12,18 12,30 24,30 24,42 12,42" fill="none" stroke="var(--accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  <line x1="36" y1="18" x2="36" y2="42" stroke="var(--accent2)" stroke-width="3" stroke-linecap="round"/>
  <line x1="36" y1="30" x2="48" y2="19" stroke="var(--accent2)" stroke-width="3" stroke-linecap="round"/>
  <line x1="36" y1="30" x2="48" y2="41" stroke="var(--accent2)" stroke-width="3" stroke-linecap="round"/>
  <g fill="#eafff7">
    <circle cx="12" cy="18" r="2.6"/><circle cx="24" cy="18" r="2.6"/><circle cx="12" cy="30" r="2.6"/>
    <circle cx="24" cy="30" r="2.6"/><circle cx="24" cy="42" r="2.6"/><circle cx="12" cy="42" r="2.6"/>
  </g>
  <g fill="#eaf4ff">
    <circle cx="36" cy="18" r="2.6"/><circle cx="36" cy="30" r="2.6"/><circle cx="36" cy="42" r="2.6"/>
    <circle cx="48" cy="19" r="2.6"/><circle cx="48" cy="41" r="2.6"/>
  </g>
</svg>
